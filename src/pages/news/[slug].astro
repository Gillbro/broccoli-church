---
import Layout from '../../layouts/Layout.astro';
import { linkify } from '../../lib/linkify';
import { withBase } from '../../lib/paths';
import { newsItems, getNewsBySlug } from '../../data/news';

export function getStaticPaths() {
	return newsItems.map((item) => ({
		params: { slug: item.slug },
	}));
}

const { slug } = Astro.params;
const item = getNewsBySlug(slug!);
if (!item) {
	throw new Error(`News not found: ${slug}`);
}
---

<Layout title={item.title} description={item.body} imageAlt={item.imageAlt} type="article">
	<article class="entry-detail">
		<header class="page-hero">
			<div class="container">
				<p class="section__eyebrow">News</p>
				<p class="entry-detail__meta">
					<time datetime={item.date}>{item.label}</time>
				</p>
				<h1>{item.title}</h1>
			</div>
		</header>

		<section class="section">
			<div class="container entry-detail__inner">
				<figure class="entry-detail__media">
					<img src={withBase(item.image)} alt={item.imageAlt} width="960" height="600" decoding="async" />
				</figure>
				<div class="entry-detail__body">
					<p class="entry-detail__lead">{item.body}</p>
					{
						item.content.map((paragraph) => (
							<p set:html={linkify(paragraph)} />
						))
					}
				</div>
				<p class="entry-detail__back">
					<a href={withBase('/news')}>← お知らせ一覧へ</a>
				</p>
			</div>
		</section>
	</article>
</Layout>

<style>
	.entry-detail__meta {
		margin: 0 0 0.75rem;
		font-size: 0.9rem;
		letter-spacing: 0.04em;
		color: var(--color-leaf);
	}

	.entry-detail__inner {
		max-width: 42rem;
	}

	.entry-detail__media {
		margin: 0 0 2.25rem;
		overflow: hidden;
		border-radius: var(--radius);
		border: 1px solid var(--color-line);
		background: var(--color-void);
	}

	.entry-detail__media img {
		width: 100%;
		height: auto;
		display: block;
	}

	.entry-detail__body {
		display: grid;
		gap: 1.25rem;
	}

	.entry-detail__body p {
		margin: 0;
		font-size: 1.05rem;
		line-height: 1.95;
		color: var(--color-text-muted);
	}

	.entry-detail__body p :global(a) {
		word-break: break-all;
	}

	.entry-detail__lead {
		padding-bottom: 1.25rem;
		border-bottom: 1px solid var(--color-line);
		font-size: 1.12rem !important;
		font-weight: 500;
		color: var(--color-forest) !important;
	}

	.entry-detail__back {
		margin: 2.75rem 0 0;
		padding-top: 1.5rem;
		border-top: 1px solid var(--color-line);
	}

	.entry-detail__back a {
		text-decoration: none;
		font-weight: 500;
	}
</style>

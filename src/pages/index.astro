---
import Layout from '../layouts/Layout.astro';
import HomeHero from '../components/HomeHero.astro';
import { withBase } from '../lib/paths';
---

<Layout>
	<HomeHero />

	<section class="section intro">
		<div class="container">
			<p class="section__eyebrow">Welcome</p>
			<h2 class="section__title">ブロッコリー教会とは？</h2>
			<p class="section__lead">
				ブロッコリー教会（通称：ブロ教）は、VRChat上でブロッコリーの魅力を広める活動を行う共同体です。ブロッコリーが好きな人、興味のある人が様々なイベントを通して交流します。
			</p>
			<div class="intro__grid">
				<article class="intro__item">
					<span class="intro__index" aria-hidden="true">01</span>
					<h3>集う</h3>
					<p>メンバー同士が、ブロッコリーを囲んで交流を重ねます。</p>
				</article>
				<article class="intro__item">
					<span class="intro__index" aria-hidden="true">02</span>
					<h3>広める</h3>
					<p>ブロッコリーを<em>デジタル空間</em>に表現し、その魅力を届けます。</p>
				</article>
				<article class="intro__item">
					<span class="intro__index" aria-hidden="true">03</span>
					<h3>味わう</h3>
					<p>決まり文句はただひとつ。<em>ブロッコリーは世界一おいしい。</em></p>
				</article>
			</div>
			<p class="intro__links">
				<a class="btn btn--outline" href={withBase('/doctrine')}>教義を読む</a>
				<a class="btn btn--outline" href={withBase('/events')}>イベントを見る</a>
			</p>
		</div>
	</section>

	<section class="section pathways">
		<div class="container">
			<p class="section__eyebrow">Explore</p>
			<h2 class="section__title">サイト案内</h2>
			<p class="section__lead">このサイトにあるコンテンツの一覧です。</p>
			<ul class="pathways__list">
				<li>
					<a href={withBase('/about')}>
						<span class="pathways__label">教会について</span>
						<span class="pathways__desc">成り立ちと活動の概要</span>
						<span class="pathways__arrow" aria-hidden="true">→</span>
					</a>
				</li>
				<li>
					<a href={withBase('/doctrine')}>
						<span class="pathways__label">教義</span>
						<span class="pathways__desc">ブロッコリー教会の思想</span>
						<span class="pathways__arrow" aria-hidden="true">→</span>
					</a>
				</li>
				<li>
					<a href={withBase('/news')}>
						<span class="pathways__label">お知らせ</span>
						<span class="pathways__desc">最新情報の紹介</span>
						<span class="pathways__arrow" aria-hidden="true">→</span>
					</a>
				</li>
				<li>
					<a href={withBase('/events')}>
						<span class="pathways__label">イベント</span>
						<span class="pathways__desc">開催イベントの概要と予定</span>
						<span class="pathways__arrow" aria-hidden="true">→</span>
					</a>
				</li>
			</ul>
		</div>
	</section>

	<section class="section join">
		<div class="container">
			<p class="section__eyebrow">Join</p>
			<h2 class="section__title">参加してみよう</h2>
			<p class="section__lead">
				VRChatより、どなたでもご参加いただけます。
			</p>

			<div class="join__row">
				<a
					class="vrc-group"
					href="https://vrc.group/BURO.8127"
					target="_blank"
					rel="noopener noreferrer"
				>
					<span class="vrc-group__grid" aria-hidden="true"></span>
					<span class="vrc-group__corner vrc-group__corner--tl" aria-hidden="true"></span>
					<span class="vrc-group__corner vrc-group__corner--br" aria-hidden="true"></span>

					<span class="vrc-group__body">
						<span class="vrc-group__label">VRChat Group</span>
						<span class="vrc-group__logo-wrap">
							<img
								class="vrc-group__logo"
								src={withBase('/images/VRChat_Logo_Black.png')}
								alt="VRChat"
								width="280"
								height="80"
								loading="lazy"
								decoding="async"
							/>
						</span>
						<span class="vrc-group__name">ブロッコリー教会</span>
						<span class="vrc-group__cta">
							グループページへ
							<span class="vrc-group__arrow" aria-hidden="true">↗</span>
						</span>
					</span>
				</a>

				<div class="join__buro" aria-hidden="true">
					<img
						src={withBase('/images/buro3.png')}
						alt=""
						width="400"
						height="400"
						loading="lazy"
						decoding="async"
					/>
				</div>
			</div>
		</div>
	</section>

	<button class="back-to-top" type="button" aria-label="ページ上部へ戻る">
		<span class="back-to-top__chevron" aria-hidden="true"></span>
	</button>
</Layout>

<script>
	const button = document.querySelector('.back-to-top');
	if (button instanceof HTMLButtonElement) {
		const toggleVisibility = () => {
			button.classList.toggle('is-visible', window.scrollY > 400);
		};

		toggleVisibility();
		window.addEventListener('scroll', toggleVisibility, { passive: true });

		button.addEventListener('click', () => {
			window.scrollTo({ top: 0, behavior: 'smooth' });
		});
	}
</script>

<style>
	.intro__grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 2rem 2.75rem;
		margin-bottom: 2.75rem;
		padding-top: 1.75rem;
		border-top: 1px solid var(--color-line);
	}

	.intro__item {
		position: relative;
		padding-left: 1rem;
		border-left: 2px solid var(--color-accent);
	}

	.intro__index {
		display: block;
		margin-bottom: 0.85rem;
		font-family: var(--font-mono);
		font-size: 0.75rem;
		letter-spacing: 0.14em;
		color: var(--color-accent);
	}

	.intro__item h3 {
		margin: 0 0 0.65rem;
		font-size: 1.2rem;
		color: var(--color-forest);
	}

	.intro__item p {
		margin: 0;
		color: var(--color-text-muted);
		font-size: 0.98rem;
	}

	.intro__item em {
		font-family: var(--font-display);
		font-style: normal;
		font-weight: 700;
		color: var(--color-accent-deep);
	}

	.intro__links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.85rem;
		margin: 0;
	}

	.intro__links .btn {
		min-width: 11.5rem;
		justify-content: center;
	}

	.pathways {
		background: var(--color-panel);
		border-block: 1px solid var(--color-line);
	}

	.pathways__list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0;
		border-top: 1px solid var(--color-line);
	}

	.pathways__list a {
		display: grid;
		grid-template-columns: minmax(8rem, 12rem) 1fr auto;
		gap: 1rem 2rem;
		align-items: center;
		padding: 1.45rem 0.35rem;
		border-bottom: 1px solid var(--color-line);
		text-decoration: none;
		color: inherit;
		transition:
			background 0.25s var(--ease-out),
			padding-left 0.25s var(--ease-out);
	}

	.pathways__list a:hover {
		padding-left: 0.65rem;
		background: rgba(3, 137, 50, 0.04);
	}

	.pathways__label {
		font-family: var(--font-display);
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--color-forest);
		letter-spacing: 0.03em;
	}

	.pathways__desc {
		color: var(--color-text-muted);
		font-size: 0.95rem;
	}

	.pathways__arrow {
		font-family: var(--font-mono);
		color: var(--color-accent);
		transition: transform 0.25s var(--ease-out);
	}

	.pathways__list a:hover .pathways__arrow {
		transform: translateX(4px);
	}

	.join {
		background:
			linear-gradient(180deg, transparent, rgba(3, 137, 50, 0.04)),
			var(--color-mist);
	}

	.join__row {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
	}

	.join__buro {
		flex-shrink: 0;
		width: min(24vw, 20rem);
		animation: join-buro-float 4.5s ease-in-out infinite;
	}

	.join__buro img {
		display: block;
		width: 100%;
		height: auto;
		filter: drop-shadow(0 10px 22px rgba(4, 21, 12, 0.18));
	}

	@keyframes join-buro-float {
		0%,
		100% {
			transform: translateY(0);
		}
		50% {
			transform: translateY(-12px);
		}
	}

	.vrc-group {
		position: relative;
		display: block;
		flex: 0 1 28rem;
		width: 100%;
		max-width: 28rem;
		margin: 0;
		padding: 2rem 1.75rem 1.85rem;
		text-decoration: none;
		color: inherit;
		background: var(--color-panel);
		border: 1px solid var(--color-line);
		border-radius: var(--radius);
		overflow: hidden;
		transition:
			transform 0.3s var(--ease-out),
			border-color 0.3s var(--ease-out);
	}

	.vrc-group:hover {
		transform: translateY(-4px);
		border-color: rgba(3, 137, 50, 0.45);
	}

	.vrc-group__grid {
		position: absolute;
		inset: 0;
		opacity: 0.35;
		pointer-events: none;
		background-image: url("data:image/svg+xml,%3Csvg width='48' height='48' viewBox='0 0 48 48' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M48 0H0v48' fill='none' stroke='%23038932' stroke-opacity='0.35' stroke-width='1'/%3E%3C/svg%3E");
	}

	.vrc-group__corner {
		position: absolute;
		width: 1.5rem;
		height: 1.5rem;
		border-color: var(--color-accent);
		border-style: solid;
		pointer-events: none;
	}

	.vrc-group__corner--tl {
		top: 0.85rem;
		left: 0.85rem;
		border-width: 2px 0 0 2px;
	}

	.vrc-group__corner--br {
		right: 0.85rem;
		bottom: 0.85rem;
		border-width: 0 2px 2px 0;
	}

	.vrc-group__body {
		position: relative;
		z-index: 1;
		display: grid;
		justify-items: center;
		gap: 0.85rem;
		text-align: center;
	}

	.vrc-group__label {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--color-accent);
	}

	.vrc-group__logo-wrap {
		display: grid;
		place-items: center;
		width: 100%;
		padding: 1.1rem 1.5rem;
		background: rgba(3, 137, 50, 0.06);
		border: 1px solid rgba(3, 137, 50, 0.18);
		border-radius: var(--radius-sm);
		transition: background 0.3s var(--ease-out);
	}

	.vrc-group:hover .vrc-group__logo-wrap {
		background: rgba(3, 137, 50, 0.1);
	}

	.vrc-group__logo {
		display: block;
		width: min(100%, 11rem);
		height: auto;
		transition: transform 0.3s var(--ease-out);
	}

	.vrc-group:hover .vrc-group__logo {
		transform: scale(1.03);
	}

	.vrc-group__name {
		font-family: var(--font-display);
		font-size: 1.15rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: var(--color-forest);
	}

	.vrc-group__cta {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding: 0.55rem 1.1rem;
		font-size: 0.88rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		color: var(--color-accent-deep);
		background: rgba(3, 137, 50, 0.08);
		border: 1px solid rgba(3, 137, 50, 0.22);
		border-radius: 999px;
		transition:
			background 0.3s var(--ease-out),
			color 0.3s var(--ease-out);
	}

	.vrc-group:hover .vrc-group__cta {
		background: var(--color-accent);
		color: var(--color-text-on-dark);
		border-color: var(--color-accent);
	}

	.vrc-group__arrow {
		font-size: 0.95em;
		transition: transform 0.3s var(--ease-out);
	}

	.vrc-group:hover .vrc-group__arrow {
		transform: translate(2px, -2px);
	}

	@media (prefers-reduced-motion: reduce) {
		.vrc-group,
		.vrc-group__logo,
		.vrc-group__arrow,
		.join__buro {
			transition: none;
			animation: none;
		}

		.vrc-group:hover {
			transform: none;
		}

		.vrc-group:hover .vrc-group__logo {
			transform: none;
		}
	}

	@media (max-width: 820px) {
		.join__buro {
			display: none;
		}

		.vrc-group {
			max-width: none;
		}
	}

	@media (max-width: 720px) {
		.intro__grid {
			grid-template-columns: 1fr;
		}

		.pathways__list a {
			grid-template-columns: 1fr auto;
			gap: 0.35rem 1rem;
		}

		.pathways__desc {
			grid-column: 1;
		}

		.pathways__arrow {
			grid-row: 1 / span 2;
			grid-column: 2;
		}
	}

	.back-to-top {
		position: fixed;
		right: 1.5rem;
		bottom: 1.5rem;
		z-index: 90;
		display: grid;
		place-items: center;
		width: 3rem;
		height: 3rem;
		padding: 0;
		border: 1px solid rgba(3, 137, 50, 0.35);
		border-radius: 999px;
		background: var(--color-accent);
		color: var(--color-text-on-dark);
		cursor: pointer;
		box-shadow: 0 12px 28px rgba(4, 21, 12, 0.22);
		opacity: 0;
		visibility: hidden;
		transform: translateY(0.75rem);
		pointer-events: none;
		transition:
			opacity 0.3s var(--ease-out),
			visibility 0.3s,
			transform 0.3s var(--ease-out),
			background 0.25s var(--ease-out);
	}

	.back-to-top__chevron {
		display: block;
		width: 0.9rem;
		height: 0.9rem;
		border-top: 0.22rem solid currentColor;
		border-right: 0.22rem solid currentColor;
		transform: translateY(0.2rem) rotate(-45deg);
	}

	.back-to-top.is-visible {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
		pointer-events: auto;
	}

	.back-to-top:hover {
		background: var(--color-accent-soft);
	}

	.back-to-top:focus-visible {
		outline: 2px solid var(--color-accent-soft);
		outline-offset: 3px;
	}

	@media (prefers-reduced-motion: reduce) {
		.back-to-top {
			transition: none;
		}
	}
</style>

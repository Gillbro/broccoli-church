---
import Layout from '../layouts/Layout.astro';

const formUrl = 'https://forms.gle/1paXLCLnSEgnBK4U8';
const formEmbedUrl =
	'https://docs.google.com/forms/d/e/1FAIpQLSf_pSDwtjLEFJ2Osz8-hadVEhZ2evRBTIuugp2vo8GiTpPwSg/viewform?embedded=true';
---

<Layout
	title="お問い合わせ"
	description="ブロッコリー教会へのお問い合わせフォーム。"
>
	<header class="page-hero">
		<div class="container">
			<p class="section__eyebrow">Contact</p>
			<h1>お問い合わせ</h1>
			<p>活動へのご質問、コラボのご相談など、お気軽にご連絡ください。</p>
		</div>
	</header>

	<section class="section contact">
		<div class="container">
			<div class="contact__head">
				<p class="section__eyebrow">Form</p>
				<h2 class="contact__title">お問い合わせフォーム</h2>
				<p class="section__lead">
					下記フォームよりお送りください。内容を確認のうえ、順次ご返信いたします。
				</p>
			</div>

			<div class="contact-form-wrap">
				<span class="contact-form-wrap__corner contact-form-wrap__corner--tl" aria-hidden="true"></span>
				<span class="contact-form-wrap__corner contact-form-wrap__corner--br" aria-hidden="true"></span>

				<div class="contact-form-wrap__inner">
					<iframe
						class="contact-form__iframe"
						src={formEmbedUrl}
						title="ブロッコリー教会 お問い合わせフォーム"
						width="640"
						height="1580"
						frameborder="0"
						marginheight="0"
						marginwidth="0"
						loading="lazy"
					>
						読み込み中…
					</iframe>
				</div>
			</div>

			<p class="contact-form__fallback">
				フォームが表示されない場合は、
				<a href={formUrl} target="_blank" rel="noopener noreferrer">Googleフォームを新しいタブで開く</a>
				からお問い合わせください。
			</p>
		</div>
	</section>
</Layout>

<style>
	.contact {
		background: var(--color-mist);
	}

	.contact__head {
		text-align: center;
		max-width: 36rem;
		margin-inline: auto;
		margin-bottom: 2.5rem;
	}

	.contact__title {
		margin: 0 0 1rem;
		font-size: clamp(1.5rem, 3vw, 1.85rem);
		color: var(--color-forest);
	}

	.contact__head .section__lead {
		margin: 0;
	}

	.contact-form-wrap {
		position: relative;
		max-width: 44rem;
		margin-inline: auto;
		padding: 1.15rem;
		border: 1px solid var(--color-line);
		border-radius: var(--radius);
		background: var(--color-panel);
		box-shadow: var(--shadow-soft);
	}

	.contact-form-wrap__inner {
		overflow: hidden;
		border-radius: calc(var(--radius) - 4px);
		background: #fff;
	}

	.contact-form-wrap__corner {
		position: absolute;
		width: 1.1rem;
		height: 1.1rem;
		border-color: var(--color-accent);
		border-style: solid;
		opacity: 0.55;
		pointer-events: none;
		z-index: 1;
	}

	.contact-form-wrap__corner--tl {
		top: 0.55rem;
		left: 0.55rem;
		border-width: 2px 0 0 2px;
	}

	.contact-form-wrap__corner--br {
		right: 0.55rem;
		bottom: 0.55rem;
		border-width: 0 2px 2px 0;
	}

	.contact-form__iframe {
		display: block;
		width: 100%;
		height: 1580px;
		border: none;
		background: #fff;
	}

	.contact-form__fallback {
		max-width: 44rem;
		margin: 1.25rem auto 0;
		font-size: 0.9rem;
		text-align: center;
		color: var(--color-text-muted);
	}

	@media (max-width: 640px) {
		.contact-form-wrap {
			padding: 0.85rem;
		}

		.contact-form__iframe {
			height: 1720px;
		}
	}
</style>

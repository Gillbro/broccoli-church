---
const year = new Date().getFullYear();
---

<footer class="site-footer">
	<div class="site-footer__inner container">
		<div class="site-footer__brand">
			<p class="site-footer__name">BROCCOLI CHURCH</p>
		</div>
		<p class="site-footer__copy">&copy; {year} ブロッコリー教会</p>
	</div>
</footer>

<style>
	.site-footer {
		background: var(--color-void);
		color: rgba(243, 248, 244, 0.65);
		padding: 3.25rem 0 2.25rem;
		border-top: 1px solid rgba(3, 137, 50, 0.3);
	}

	.site-footer__inner {
		display: grid;
		gap: 1.75rem;
	}

	.site-footer__brand {
		text-align: center;
	}

	.site-footer__name {
		margin: 0 0 0.4rem;
		font-family: var(--font-display);
		font-size: 1.15rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		color: var(--color-text-on-dark);
	}

	.site-footer__nav {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 1.5rem;
	}

	.site-footer__nav a {
		color: rgba(243, 248, 244, 0.65);
		text-decoration: none;
		font-size: 0.9rem;
	}

	.site-footer__nav a:hover {
		color: var(--color-leaf);
	}

	.site-footer__copy {
		margin: 0;
		padding-top: 1.1rem;
		border-top: 1px solid rgba(243, 248, 244, 0.1);
		font-size: 0.78rem;
		font-family: var(--font-mono);
		letter-spacing: 0.04em;
		opacity: 0.7;
		text-align: center;
	}
</style>
